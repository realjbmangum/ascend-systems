---
/**
 * Service detail page — `/services/[slug]`
 *
 * Set 1 of the programmatic SEO plan (docs/seo/2026-05-12-programmatic-seo.html).
 * Content lives in src/data/services.ts; this file is the template.
 *
 * Rendered as plain Astro markup rather than through PageIsland — these are
 * static content pages with no interactivity, and PageIsland's `PageName`
 * union would need a React component per slug for no benefit.
 *
 * Schema: Service + FAQPage + BreadcrumbList, all referencing the sitewide
 * entities by @id rather than restating them.
 */
import Layout from '../../layouts/Layout.astro';
import JsonLd from '../../components/JsonLd.astro';
import { SERVICE_PAGES, getServicePage, type ServicePage } from '../../data/services';
import { PROJECTS } from '../../data/portfolio';
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';

export async function getStaticPaths() {
  return SERVICE_PAGES.map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}

const { service } = Astro.props as { service: ServicePage };
const canonical = `/services/${service.slug}`;
const origin = 'https://ascendsystems.ai';

const proofProject = service.proof.portfolioSlug
  ? PROJECTS.find((p) => p.slug === service.proof.portfolioSlug)
  : undefined;

// Only render the illustration if the file is actually present, so dropping
// images in later lights them up with no code change and a missing file never
// produces a broken <img>.
const image =
  service.image &&
  existsSync(fileURLToPath(new URL(`../../../public${service.image.src}`, import.meta.url)))
    ? service.image
    : undefined;

const related = service.relatedServices
  .map((s) => getServicePage(s))
  .filter((s): s is ServicePage => Boolean(s));

// Service — keeps the same @id as the entry on /services so the two pages
// describe one entity rather than competing duplicates.
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${origin}/services#${service.serviceAnchor}`,
  name: service.shortName,
  serviceType: service.serviceType,
  description: service.metaDescription,
  url: `${origin}${canonical}`,
  provider: { '@id': `${origin}/#organization` },
  areaServed: [
    { '@type': 'City', name: 'Charlotte' },
    { '@type': 'AdministrativeArea', name: 'North Carolina' },
    { '@type': 'Country', name: 'United States' },
  ],
  audience: {
    '@type': 'BusinessAudience',
    audienceType: 'Owner-operator and mid-market businesses',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${origin}${canonical}#faq`,
  mainEntity: service.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${origin}/` },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${origin}/services` },
    { '@type': 'ListItem', position: 3, name: service.shortName, item: `${origin}${canonical}` },
  ],
};
---

<Layout
  title={service.metaTitle}
  description={service.metaDescription}
  canonical={canonical}
>
  <JsonLd slot="head" data={serviceSchema} />
  <JsonLd slot="head" data={faqSchema} />
  <JsonLd slot="head" data={breadcrumbSchema} />

  <!-- Hero — two columns: copy left, illustration right. The image lives here
       rather than in its own full-width band below the problem section, which
       stacked three full-width blocks in a row and made the page a scroll. -->
  <section class="bg-charcoal text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-2 text-sm text-surface-200">
          <li><a href="/" class="hover:text-orange transition-colors">Home</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/services" class="hover:text-orange transition-colors">Services</a></li>
          <li aria-hidden="true">/</li>
          <li class="text-white" aria-current="page">{service.shortName}</li>
        </ol>
      </nav>

      <div class:list={['grid gap-10 lg:gap-14 items-center', image && 'lg:grid-cols-12']}>
        <div class:list={[image && 'lg:col-span-5']}>
          <p class="text-xs font-mono uppercase tracking-[0.18em] text-orange mb-4">
            {service.hero.eyebrow}
          </p>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-5 text-balance">
            {service.hero.headline}
          </h1>
          <p class="text-lg text-surface-200 leading-relaxed mb-8 text-pretty">
            {service.hero.subhead}
          </p>
          <div class="flex flex-wrap gap-3">
            <a
              href="/contact"
              class="bg-orange hover:bg-orange-dark text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors"
            >
              Book a discovery call
            </a>
            <a
              href="/tools/cost-calculator"
              class="border border-surface-200/40 hover:border-orange text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors"
            >
              Estimate your project cost
            </a>
          </div>
        </div>

        {image && (
          <figure class="lg:col-span-7">
            <img
              src={image.src}
              alt={image.alt}
              width="960"
              height="960"
              fetchpriority="high"
              decoding="async"
              class="w-full rounded-xl border border-charcoal-lighter shadow-lg"
            />
            <figcaption class="mt-3 text-xs text-gray-400 leading-snug">
              Illustrative mockup — not a client system.
            </figcaption>
          </figure>
        )}
      </div>
    </div>
  </section>

  <!-- Problem — heading pinned left, prose in a readable measure on the right,
       so long-form copy doesn't run the full page width. -->
  <section class="bg-white border-t border-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
      <div class="grid gap-8 lg:grid-cols-12 lg:gap-14">
        <h2 class="text-2xl sm:text-3xl font-bold text-charcoal lg:col-span-4 text-balance lg:sticky lg:top-24 lg:self-start">
          {service.problem.headline}
        </h2>
        <div class="lg:col-span-8">
          {service.problem.body.map((para) => (
            <p class="text-[17px] leading-[1.75] text-charcoal-lighter mb-5 text-pretty">{para}</p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Approach — two columns on desktop so five steps don't become five
       full-width rows of scrolling. -->
  <section class="bg-surface border-t border-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
      <h2 class="text-2xl sm:text-3xl font-bold text-charcoal mb-10">
        How an engagement runs
      </h2>
      <ol class="grid gap-x-12 gap-y-8 md:grid-cols-2">
        {service.approach.map((s, i) => (
          <li class="flex gap-4">
            <span
              class="shrink-0 w-8 h-8 rounded-full bg-charcoal text-white font-mono text-xs flex items-center justify-center"
              aria-hidden="true"
            >
              {i + 1}
            </span>
            <div>
              <h3 class="font-semibold text-charcoal mb-1.5">{s.step}</h3>
              <p class="text-[16px] leading-[1.65] text-charcoal-lighter text-pretty">{s.detail}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Proof -->
  <section class="bg-white border-t border-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
      <div class="grid gap-8 lg:grid-cols-12 lg:gap-14">
        <div class="lg:col-span-7">
          <p class="text-xs font-mono uppercase tracking-[0.18em] text-orange mb-3">Proof</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-charcoal mb-5 text-balance">
            {service.proof.headline}
          </h2>
          <p class="text-[17px] leading-[1.75] text-charcoal-lighter text-pretty">
            {service.proof.body}
          </p>
        </div>
        <div class="lg:col-span-5 lg:pt-10">
          {service.proof.outcome && (
            <p class="rounded-xl border border-orange/30 bg-orange-glow p-5 font-mono text-sm leading-relaxed text-charcoal mb-5">
              {service.proof.outcome}
            </p>
          )}
          {proofProject && (
            <a
              href={`/portfolio/${proofProject.slug}`}
              class="inline-flex items-center gap-2 text-orange-dark font-semibold hover:underline underline-offset-4"
            >
              Read the {proofProject.name} case study →
            </a>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="bg-charcoal text-white border-t border-charcoal-light">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
      <h2 class="text-2xl sm:text-3xl font-bold mb-6">{service.pricing.headline}</h2>
      <p class="text-[17px] leading-[1.75] text-surface-200 mb-10">{service.pricing.body}</p>
      <dl class="grid gap-4 sm:grid-cols-3">
        {service.pricing.anchors.map((a) => (
          <div class="rounded-xl border border-charcoal-lighter bg-charcoal-light p-5">
            <dt class="text-xs font-mono uppercase tracking-[0.14em] text-orange mb-2">
              {a.label}
            </dt>
            <dd class="text-white font-semibold leading-snug">{a.value}</dd>
          </div>
        ))}
      </dl>
      <p class="mt-8 text-sm text-surface-200">
        Run your own numbers on the
        <a href="/tools/cost-calculator" class="text-orange hover:underline underline-offset-4">
          software cost calculator
        </a>.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-white border-t border-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
      <h2 class="text-2xl sm:text-3xl font-bold text-charcoal mb-10">
        Questions about {service.shortName.toLowerCase()}
      </h2>
      {/* Constrained inside the wide section — a full-width accordion pushes
          answer text past a comfortable reading measure. */}
      <div class="max-w-3xl divide-y divide-gray-200 border-t border-gray-200">
        {service.faqs.map((f) => (
          <details class="group py-6">
            <summary
              class="flex cursor-pointer list-none items-start justify-between gap-4 font-semibold text-charcoal"
            >
              <span>{f.q}</span>
              <span
                class="shrink-0 text-orange transition-transform group-open:rotate-45"
                aria-hidden="true"
              >+</span>
            </summary>
            <p class="mt-4 text-[17px] leading-[1.75] text-charcoal-lighter">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related + CTA -->
  <section class="bg-surface border-t border-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
      <h2 class="text-2xl sm:text-3xl font-bold text-charcoal mb-8">Related services</h2>
      <ul class="grid gap-4 sm:grid-cols-3 mb-16">
        {related.map((r) => (
          <li>
            <a
              href={`/services/${r.slug}`}
              class="block h-full rounded-xl border border-surface-200 bg-white p-5 hover:border-orange transition-colors"
            >
              <span class="block font-semibold text-charcoal mb-1">{r.shortName}</span>
              <span class="block text-sm text-charcoal-lighter leading-snug">
                {r.hero.subhead.split('—')[0].trim()}
              </span>
            </a>
          </li>
        ))}
      </ul>

      <div class="rounded-2xl bg-charcoal text-white p-8 sm:p-10">
        <h2 class="text-2xl font-bold mb-3">{service.cta.headline}</h2>
        <p class="text-surface-200 leading-relaxed mb-6">{service.cta.body}</p>
        <div class="flex flex-wrap gap-3">
          <a
            href="/contact"
            class="bg-orange hover:bg-orange-dark text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors"
          >
            Book a discovery call
          </a>
          <a
            href="/portfolio"
            class="border border-surface-200/40 hover:border-orange text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors"
          >
            See the work
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
