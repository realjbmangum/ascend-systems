---
/**
 * Case study page — `/portfolio/[slug]`
 *
 * Astro generates one static page per project at build time via
 * getStaticPaths(), pulling the slug list from src/data/portfolio.ts.
 * Each page renders the existing React <CaseStudy /> inside PageIsland
 * with the routePattern wired up so useParams returns the slug.
 *
 * Phase 3 schema (Article + BreadcrumbList) is generated per-slug below.
 */
import Layout from '../../layouts/Layout.astro';
import JsonLd from '../../components/JsonLd.astro';
import PageIsland from '../../components/PageIsland';
import { PROJECTS } from '../../data/portfolio';
import { getEntry, render, type CollectionEntry } from 'astro:content';
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';

export async function getStaticPaths() {
  return PROJECTS.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { slug } = Astro.params;

// Long-form case study lookup. When src/content/case-studies/{slug}.md
// exists, render its body below the React skeleton. Otherwise the page
// falls back to the basic layout (existing behavior).
let caseStudyEntry: CollectionEntry<'case-studies'> | undefined;
try {
  caseStudyEntry = await getEntry('case-studies', slug as string);
} catch {
  caseStudyEntry = undefined;
}
const CaseStudyBody = caseStudyEntry ? (await render(caseStudyEntry)).Content : null;

const canonical = `/portfolio/${slug}`;
const cs = caseStudyEntry?.data;

// Prefer the hand-written SEO copy in the case study frontmatter; fall back
// to the generated title / project tagline when no .md file exists.
const title = cs?.seoTitle ?? `${project.name} — Case Study | Ascend Systems`;
const description = cs?.seoDescription ?? project.tagline;

// Absolute OG image — the case study hero, but ONLY if the file actually
// exists on disk. Several `hero:` paths in frontmatter point at images that
// were never committed; a 404 OG image is worse than the site default, so we
// verify at build time and fall back. Self-corrects once the file is added.
/** True when a /public-relative path exists on disk at build time. */
const onDisk = (p: string) =>
  existsSync(fileURLToPath(new URL(`../../../public${p}`, import.meta.url)));

const heroOnDisk = cs?.hero && onDisk(cs.hero);

// Only render screenshots whose files are actually present.
const shots = (cs?.screenshots ?? []).filter((s) => onDisk(s.src));

/**
 * Set true while the screenshot set is AI-generated rather than captured from
 * the running product. Adds an "illustrative mockup" caption so the images are
 * never presented as real product captures. Flip to false once these are
 * replaced with real screenshots (4 of these 5 products are live and can
 * simply be captured).
 */
const IMAGES_ARE_ILLUSTRATIVE = true;
const ogImage = heroOnDisk
  ? `https://ascendsystems.ai${cs!.hero}`
  : 'https://ascendsystems.ai/og-image.png';

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `https://ascendsystems.ai${canonical}#article`,
  headline: cs?.title ?? project.name,
  description: cs?.seoDescription ?? project.description,
  image: ogImage,
  author: { '@id': 'https://ascendsystems.ai/#brian-mangum' },
  publisher: { '@id': 'https://ascendsystems.ai/#organization' },
  url: `https://ascendsystems.ai${canonical}`,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://ascendsystems.ai${canonical}`,
  },
  isPartOf: { '@id': 'https://ascendsystems.ai/#website' },
  // Dates describe the case study article itself, not the engagement.
  // Omitted entirely when unknown — a wrong date is worse than none.
  ...(cs?.publishDate ? { datePublished: cs.publishDate } : {}),
  ...(cs?.updatedDate ? { dateModified: cs.updatedDate } : {}),
  about: (project.tags ?? []).map((t: string) => ({ '@type': 'Thing', name: t })),
  ...(cs?.stack?.length ? { keywords: cs.stack.join(', ') } : {}),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://ascendsystems.ai/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Portfolio',
      item: 'https://ascendsystems.ai/portfolio',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: project.name,
      item: `https://ascendsystems.ai${canonical}`,
    },
  ],
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  ogType="article"
>
  <JsonLd slot="head" data={articleSchema} />
  <JsonLd slot="head" data={breadcrumbSchema} />
  <PageIsland
    page="case-study"
    initialPath={canonical}
    routePattern="/portfolio/:slug"
    client:load
  />
  {CaseStudyBody && (
    <section class="bg-white border-t border-gray-200 py-20 sm:py-28">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 case-study-body">
        <CaseStudyBody />

        {/* Screenshot gallery. The `screenshots` frontmatter was declared in
            content.config.ts but never rendered — declaring an image is not
            the same as showing it. Only files that actually exist on disk are
            emitted, so partial sets degrade cleanly instead of producing
            broken <img> tags. */}
        {shots.length > 0 && (
          <div class="mt-16 not-prose">
            <h2>Screenshots</h2>
            {shots.map((s) => (
              <figure class="my-8">
                <img src={s.src} alt={s.alt} loading="lazy" decoding="async" />
                <figcaption class="mt-2 text-sm text-gray-500 leading-snug">
                  {s.alt}
                  {IMAGES_ARE_ILLUSTRATIVE && (
                    <span class="ml-1 text-gray-400">— illustrative mockup</span>
                  )}
                </figcaption>
              </figure>
            ))}
          </div>
        )}
      </div>
    </section>
  )}
</Layout>

<style is:global>
  /* Long-form case study typography — applies only inside .case-study-body */
  .case-study-body {
    font-size: 17px;
    line-height: 1.75;
    color: #2A2A2E;
  }
  .case-study-body h2 {
    font-size: 28px;
    line-height: 1.25;
    font-weight: 700;
    letter-spacing: -0.015em;
    margin: 56px 0 16px;
    color: #1E2A32;
  }
  .case-study-body h3 {
    font-size: 20px;
    line-height: 1.3;
    font-weight: 600;
    margin: 36px 0 12px;
    color: #1E2A32;
  }
  .case-study-body h4 {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #6B7280;
    margin: 24px 0 8px;
  }
  .case-study-body p { margin: 0 0 18px; }
  .case-study-body ul, .case-study-body ol { margin: 0 0 18px; padding-left: 26px; }
  .case-study-body li { margin-bottom: 8px; }
  .case-study-body strong { font-weight: 600; color: #1E2A32; }
  .case-study-body code {
    background: #F3F3F2;
    color: #1E2A32;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.92em;
    font-family: 'JetBrains Mono', 'SF Mono', Menlo, monospace;
  }
  .case-study-body pre {
    background: #1E2A32;
    color: #E5E5E3;
    padding: 20px 24px;
    border-radius: 8px;
    overflow-x: auto;
    margin: 16px 0 24px;
    font-family: 'JetBrains Mono', 'SF Mono', Menlo, monospace;
    font-size: 14px;
  }
  .case-study-body pre code { background: transparent; color: inherit; padding: 0; }
  .case-study-body blockquote {
    margin: 24px 0;
    padding: 16px 24px;
    border-left: 3px solid #D4632C;
    background: #FEF5F0;
    color: #1E2A32;
  }
  .case-study-body table {
    width: 100%;
    border-collapse: collapse;
    margin: 20px 0;
    font-size: 15px;
  }
  .case-study-body th, .case-study-body td {
    padding: 10px 14px;
    border-bottom: 1px solid #E5E5E3;
    text-align: left;
    vertical-align: top;
  }
  .case-study-body th {
    background: #F3F3F2;
    font-weight: 600;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .case-study-body a {
    color: #B85328;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .case-study-body img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 24px 0;
    box-shadow: 0 4px 16px rgba(28,28,30,0.08);
  }
  .case-study-body hr {
    border: none;
    border-top: 1px solid #E5E5E3;
    margin: 40px 0;
  }
</style>
